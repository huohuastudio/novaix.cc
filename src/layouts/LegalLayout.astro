---
import Layout from "./Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  frontmatter?: { title?: string; description?: string };
  title?: string;
  description?: string;
}

const title = Astro.props.frontmatter?.title ?? Astro.props.title ?? "";
const description = Astro.props.frontmatter?.description ?? Astro.props.description;
---

<Layout title={`${title} — Novaix`} description={description}>
  <Header />
  <main class="px-6 pb-20 pt-32 sm:pt-36">
    <article class="legal-content mx-auto max-w-3xl">
      <slot />
    </article>
  </main>
  <Footer />
</Layout>

<style is:global>
  .legal-content h1 {
    font-family: var(--font-display);
    font-size: 1.875rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-zinc-900, #18181b);
    margin-bottom: 0.5rem;
  }
  .legal-content h1 + p {
    color: var(--color-zinc-400, #a1a1aa);
    font-size: 0.875rem;
    margin-bottom: 2.5rem;
  }
  .legal-content h2 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-zinc-900, #18181b);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .legal-content h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-zinc-900, #18181b);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .legal-content p {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--color-zinc-600, #52525b);
    margin-bottom: 1rem;
  }
  .legal-content ul, .legal-content ol {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--color-zinc-600, #52525b);
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .legal-content ul { list-style-type: disc; }
  .legal-content ol { list-style-type: decimal; }
  .legal-content li { margin-bottom: 0.375rem; }
  .legal-content a {
    color: var(--color-accent);
    text-decoration: none;
  }
  .legal-content a:hover { text-decoration: underline; }
  .legal-content strong { color: var(--color-zinc-800, #27272a); }
  .legal-content hr {
    border: none;
    border-top: 1px solid var(--color-zinc-200, #e4e4e7);
    margin: 2.5rem 0 1rem;
  }

  @media (prefers-color-scheme: dark) {
    .legal-content h1,
    .legal-content h2,
    .legal-content h3 { color: var(--color-zinc-50, #fafafa); }
    .legal-content p,
    .legal-content ul,
    .legal-content ol { color: var(--color-zinc-400, #a1a1aa); }
    .legal-content strong { color: var(--color-zinc-200, #e4e4e7); }
    .legal-content hr { border-top-color: var(--color-zinc-800, #27272a); }
  }
</style>
