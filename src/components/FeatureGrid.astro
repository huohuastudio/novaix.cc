---
interface Props {
  title?: string;
  description?: string;
  items: Array<{ title: string; description: string }>;
  bg?: boolean;
}

const { title, description, items, bg = false } = Astro.props;
---

<section class:list={["px-6 py-20 sm:py-28", bg && "bg-zinc-50/50 dark:bg-zinc-900/50"]}>
  <div class="mx-auto max-w-6xl">
    {(title || description) && (
      <div class="mb-14" data-animate="blur">
        {title && <h2 class="font-display text-2xl font-bold tracking-tight text-zinc-900 sm:text-3xl dark:text-zinc-50">{title}</h2>}
        {description && <p class="mt-3 max-w-lg text-zinc-500 dark:text-zinc-400">{description}</p>}
      </div>
    )}

    <div class="grid gap-x-12 gap-y-10 sm:grid-cols-2 lg:grid-cols-4">
      {items.map((item, i) => (
        <div data-animate="up" style={`--stagger:${i * 0.06}s`}>
          <h3 class="font-display text-[0.95rem] font-bold text-zinc-900 dark:text-zinc-50">{item.title}</h3>
          <p class="mt-2 text-[0.84rem] leading-relaxed text-zinc-500 dark:text-zinc-400">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
