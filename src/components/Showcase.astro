---
/**
 * layout:
 *  "pair"     — 双列并排（上文下图）
 *  "left"     — 左文右图
 *  "right"    — 右文左图
 */
interface Item {
  title: string;
  description: string;
  features?: string[];
  image: string;
  imageAlt: string;
}

interface Props {
  layout?: "pair" | "left" | "right";
  tag?: string;
  title?: string;
  description?: string;
  features?: string[];
  items?: Item[];
  image?: string;
  imageAlt?: string;
  bg?: boolean;
}

const { layout = "pair", tag, title, description, features, items = [], image, imageAlt, bg = false } = Astro.props;
---

{layout === "pair" && (
  <section class:list={["px-6", bg && "bg-zinc-50/50 dark:bg-zinc-900/50"]}>
    <div class="mx-auto max-w-6xl">
      <div class="grid divide-x divide-zinc-200/80 sm:grid-cols-2 dark:divide-zinc-700/80">
        {items.map((item, i) => (
          <div
            class:list={["flex flex-col pb-0 pt-16 sm:pt-20", i % 2 === 0 ? "pr-8 sm:pr-12" : "pl-8 sm:pl-12"]}
            data-animate={i === 0 ? "left" : "right"}
            style={`--stagger:${i * 0.1}s`}
          >
            <h3 class="font-display text-xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50">{item.title}</h3>
            <p class="mt-3 min-h-[3.5rem] text-[0.92rem] leading-relaxed text-zinc-500 dark:text-zinc-400">{item.description}</p>
            <div class="magnify relative mt-8 overflow-hidden rounded-t-xl border border-b-0 border-zinc-200/80 bg-zinc-50 dark:border-zinc-700/80 dark:bg-zinc-800">
              <img src={item.image} alt={item.imageAlt} class="w-full object-cover object-top" loading="lazy" />
              <div class:list={["pointer-events-none absolute inset-0 bg-gradient-to-b from-transparent via-transparent", bg ? "to-[#fafbfc] dark:to-zinc-900" : "to-white dark:to-zinc-950"]}></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

{(layout === "left" || layout === "right") && (
  <section class:list={["px-6 py-20 sm:py-28", bg && "bg-zinc-50/50 dark:bg-zinc-900/50"]}>
    <div class:list={["mx-auto grid max-w-6xl items-center gap-10 lg:gap-16", layout === "left" ? "lg:grid-cols-[1fr_1.2fr]" : "lg:grid-cols-[1.2fr_1fr]"]}>
      <div data-animate={layout} class:list={[layout === "right" && "lg:order-last"]}>
        {tag && <p class="font-mono text-xs font-medium uppercase tracking-[0.2em] text-accent">{tag}</p>}
        <h2 class="mt-3 font-display text-2xl font-bold tracking-tight text-zinc-900 sm:text-3xl dark:text-zinc-50">{title}</h2>
        <p class="mt-4 leading-relaxed text-zinc-500 dark:text-zinc-400">{description}</p>
        {features && (
          <ul class="mt-6 space-y-3">
            {features.map((f) => (
              <li class="flex items-start gap-3 text-[0.9rem] text-zinc-600 dark:text-zinc-300">
                <svg class="mt-[3px] h-4 w-4 shrink-0 text-accent" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {f}
              </li>
            ))}
          </ul>
        )}
      </div>
      <div data-animate="scale" style={`--stagger:${layout === "left" ? ".15" : ".05"}s`}>
        <div class="magnify overflow-hidden rounded-2xl border border-zinc-200/80 bg-zinc-50 dark:border-zinc-700/80 dark:bg-zinc-800">
          <img src={image} alt={imageAlt} class="w-full object-cover object-top" loading="lazy" />
        </div>
      </div>
    </div>
  </section>
)}
