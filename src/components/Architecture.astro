<section id="deploy" class="bg-gradient-to-b from-zinc-50 to-white px-6 py-20 sm:py-28 dark:from-zinc-900 dark:to-zinc-950">
  <div class="mx-auto max-w-6xl">
    <div class="mb-14" data-animate>
      <p class="font-mono text-xs font-medium uppercase tracking-[0.2em] text-accent">Deploy</p>
      <h2 class="mt-3 font-display text-2xl font-bold tracking-tight text-zinc-900 sm:text-3xl dark:text-zinc-50">
        三步上线
      </h2>
      <p class="mt-4 max-w-lg text-zinc-500 dark:text-zinc-400">
        不需要 Docker，不需要数据库。下载、解压、运行——就这么简单。
      </p>
    </div>

    <div class="grid items-start gap-10 lg:grid-cols-5">
      <!-- Terminal -->
      <div class="lg:col-span-3" data-animate="left" style="--stagger:.1s">
        <div class="overflow-hidden rounded-2xl bg-zinc-900">
          <div class="flex items-center gap-1.5 border-b border-zinc-800 px-5 py-3">
            <span class="h-[10px] w-[10px] rounded-full bg-[#ff5f57]"></span>
            <span class="h-[10px] w-[10px] rounded-full bg-[#febc2e]"></span>
            <span class="h-[10px] w-[10px] rounded-full bg-[#28c840]"></span>
            <span class="ml-4 font-mono text-[0.7rem] text-zinc-500">Terminal</span>
          </div>
          <div class="space-y-4 break-all p-6 font-mono text-[0.82rem] leading-relaxed">
            <div>
              <div class="text-zinc-500"># 下载</div>
              <div class="text-zinc-200">
                <span class="text-emerald-400">$</span> wget https://github.com/huohuastudio/novaix-releases/releases/latest/download/<wbr/>novaix_linux_amd64.tar.gz
              </div>
            </div>
            <div>
              <div class="text-zinc-500"># 解压</div>
              <div class="text-zinc-200">
                <span class="text-emerald-400">$</span> tar -xzf novaix_linux_amd64.tar.gz
              </div>
            </div>
            <div>
              <div class="text-zinc-500"># 启动</div>
              <div class="text-zinc-200">
                <span class="text-emerald-400">$</span> ./novaix
              </div>
              <div class="mt-1 text-emerald-400">✓ 服务已启动 http://localhost:8080</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Benefits -->
      <div class="space-y-4 lg:col-span-2">
        {[
          {
            label: "单文件",
            detail: "Go + React 编译为单个二进制。没有运行时依赖，没有 node_modules，没有容器镜像。",
          },
          {
            label: "SQLite 默认",
            detail: "零配置开箱即用。需要 MySQL？改一行配置即可切换。",
          },
          {
            label: "在线更新",
            detail: "后台一键升级，自动备份、迁移、替换。SQLite 迁移失败可自动回滚。",
          },
        ].map((item, i) => (
          <div
            class="rounded-xl border border-zinc-200/60 bg-white p-5 dark:border-zinc-700/60 dark:bg-zinc-900"
            data-animate
            style={`--stagger:${0.15 + i * 0.08}s`}
          >
            <div class="flex items-center gap-3">
              <span class="flex h-7 w-7 items-center justify-center rounded-md bg-accent-50 font-mono text-xs font-bold text-accent dark:bg-accent/10">
                {i + 1}
              </span>
              <h3 class="font-display text-[0.95rem] font-bold text-zinc-900 dark:text-zinc-50">{item.label}</h3>
            </div>
            <p class="mt-2 pl-10 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">{item.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
