---
const groups = [
  {
    title: "产品",
    items: [
      { label: "功能特性", href: "#features" },
      { label: "更新日志", href: "https://github.com/huohuastudio/novaix-releases/releases" },
      { label: "主题市场", href: "https://github.com/huohuastudio/novaix-releases#主题市场" },
    ],
  },
  {
    title: "资源",
    items: [
      { label: "文档", href: "https://docs.huohuastudio.com/novaix" },
      { label: "GitHub", href: "https://github.com/huohuastudio/novaix-releases" },
      { label: "提交 Issue", href: "https://github.com/huohuastudio/novaix-releases/issues" },
    ],
  },
  {
    title: "法律",
    items: [
      { label: "许可协议", href: "/license" },
      { label: "服务条款", href: "/terms" },
      { label: "隐私政策", href: "/privacy" },
    ],
  },
];
---

<footer class="bg-zinc-950 px-6 pb-10 pt-16 text-zinc-400">
  <div class="mx-auto max-w-6xl">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <a href="/" class="flex items-center gap-2 font-display text-[0.95rem] font-bold text-white">
          <img src="/logo.svg" alt="" class="h-6 w-6" aria-hidden="true" />
          Novaix
        </a>
        <p class="mt-3 text-sm leading-relaxed">
          商业化 IDC 管理系统
          <br />
          面向中小型 VPS 服务商
        </p>
      </div>

      {groups.map((g) => (
        <div>
          <h4 class="text-[0.8rem] font-semibold uppercase tracking-wider text-zinc-500">{g.title}</h4>
          <ul class="mt-3 space-y-2">
            {g.items.map((item) => (
              <li>
                <a
                  href={item.href}
                  target={item.href.startsWith("http") || item.href.startsWith("mailto") ? "_blank" : undefined}
                  rel={item.href.startsWith("http") ? "noopener noreferrer" : undefined}
                  class="text-sm transition-colors hover:text-white"
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 border-t border-zinc-800 pt-6 text-[0.75rem] text-zinc-600">
      &copy; {new Date().getFullYear()} Spark Studio. All rights reserved.
    </div>
  </div>
</footer>
