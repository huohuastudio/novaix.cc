---
interface Feature {
  name: string;
  free: boolean;
}

const features: Feature[] = [
  { name: "实例全生命周期管理", free: true },
  { name: "套餐 / 订单 / 计费", free: true },
  { name: "多支付渠道", free: true },
  { name: "工单系统", free: true },
  { name: "CMS 内容管理", free: true },
  { name: "主题系统", free: true },
  { name: "在线更新", free: true },
  { name: "不限节点数（免费版 ≤ 2）", free: false },
  { name: "HA 高可用（自动疏散）", free: false },
  { name: "多数据库（MySQL / PostgreSQL）", free: false },
  { name: "告警通知", free: false },
  { name: "私有网络（VPC）", free: false },
  { name: "代理商系统", free: false },
  { name: "共享 IP / NAT", free: false },
  { name: "插件系统", free: false },
];
---

<section id="pricing" class="px-6 py-20 sm:py-28">
  <div class="mx-auto max-w-5xl">
    <div class="text-center" data-animate="blur">
      <h2 class="font-display text-2xl font-bold tracking-tight text-zinc-900 sm:text-3xl dark:text-zinc-50">
        免费版与授权版
      </h2>
      <p class="mt-3 text-zinc-500 dark:text-zinc-400">
        部署即用，无需注册。免费版满足小规模运营，授权版解锁全部能力。
      </p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2" data-animate="up">
      <!-- 免费版 -->
      <div class="relative flex flex-col rounded-2xl border border-zinc-200 p-8 dark:border-zinc-700">
        <div class="mb-6">
          <h3 class="font-display text-lg font-bold text-zinc-900 dark:text-zinc-50">免费版</h3>
          <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">部署即用，永久免费</p>
          <div class="mt-4">
            <span class="font-display text-4xl font-extrabold text-zinc-900 dark:text-zinc-50">¥0</span>
          </div>
        </div>
        <ul class="space-y-3 text-sm">
          {features.map((f) => (
            <li class={`flex items-start gap-2.5 ${f.free ? "text-zinc-600 dark:text-zinc-400" : "text-zinc-300 dark:text-zinc-600"}`}>
              {f.free ? (
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              ) : (
                <svg class="mt-0.5 h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 12H6"/></svg>
              )}
              {f.name}
            </li>
          ))}
        </ul>
        <a
          href="https://github.com/huohuastudio/novaix-releases/releases"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-10 flex w-full items-center justify-center rounded-lg border border-zinc-300 py-2.5 text-sm font-semibold text-zinc-700 transition-colors hover:bg-zinc-50 dark:border-zinc-600 dark:text-zinc-300 dark:hover:bg-zinc-800"
        >
          免费下载
        </a>
      </div>

      <!-- 授权版 -->
      <div class="relative flex flex-col rounded-2xl border-2 border-accent p-8 shadow-lg shadow-accent/5">
        <div class="absolute -top-3.5 right-6 rounded-full bg-accent px-3.5 py-1 text-xs font-semibold text-white">推荐</div>
        <div class="mb-6">
          <h3 class="font-display text-lg font-bold text-zinc-900 dark:text-zinc-50">授权版</h3>
          <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">解锁全部功能，不限规模</p>
          <div class="mt-4 flex items-baseline gap-1">
            <span class="font-display text-4xl font-extrabold text-zinc-900 dark:text-zinc-50">按需</span>
            <span class="text-sm text-zinc-500 dark:text-zinc-400">订阅</span>
          </div>
        </div>
        <ul class="space-y-3 text-sm text-zinc-600 dark:text-zinc-400">
          {features.map((f) => (
            <li class="flex items-start gap-2.5">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              {f.name}
            </li>
          ))}
        </ul>
        <a
          href="https://huohuastudio.com/products/novaix/buy"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-10 flex w-full items-center justify-center rounded-lg bg-accent py-2.5 text-sm font-semibold text-white transition-colors hover:bg-accent/90"
        >
          获取授权
        </a>
      </div>
    </div>
  </div>
</section>
