---
const links = [
  { label: "功能", href: "#features" },
  { label: "部署", href: "#deploy" },
  { label: "FAQ", href: "#faq" },
  { label: "文档", href: "https://docs.huohuastudio.com/novaix", ext: true },
  { label: "GitHub", href: "https://github.com/huohuastudio/novaix-releases", ext: true },
];
---

<header id="hdr" class="fixed top-0 z-50 w-full transition-[background,box-shadow] duration-300">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-2 font-display text-[1.05rem] font-bold tracking-tight text-zinc-900 dark:text-zinc-50">
      <img src="/logo.svg" alt="" class="h-7 w-7" aria-hidden="true" />
      Novaix
    </a>

    <nav class="hidden items-center gap-7 md:flex">
      {links.map((l) => (
        <a
          href={l.href}
          target={l.ext ? "_blank" : undefined}
          rel={l.ext ? "noopener noreferrer" : undefined}
          class="inline-flex items-center gap-0.5 text-[0.84rem] text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-50"
        >
          {l.label}
          {l.ext && (
            <svg class="h-3 w-3 -translate-y-px opacity-40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H8M17 7v9" />
            </svg>
          )}
        </a>
      ))}
      <a
        href="https://github.com/huohuastudio/novaix-releases/releases"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-lg bg-zinc-900 px-4 py-1.5 text-[0.84rem] font-medium text-white transition-colors hover:bg-zinc-700 dark:bg-white dark:text-zinc-900 dark:hover:bg-zinc-200"
      >
        下载
      </a>
    </nav>

    <button id="mbtn" class="md:hidden" aria-label="菜单">
      <svg class="h-5 w-5 text-zinc-600 dark:text-zinc-300" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24">
        <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16" />
      </svg>
    </button>
  </div>

  <div id="mmenu" class="hidden border-t border-zinc-100 bg-white px-6 py-5 md:hidden dark:border-zinc-800 dark:bg-zinc-950">
    {links.map((l) => (
      <a href={l.href} target={l.ext ? "_blank" : undefined} class="flex items-center gap-0.5 py-2 text-sm text-zinc-600 dark:text-zinc-300">
        {l.label}
        {l.ext && (
          <svg class="h-3 w-3 -translate-y-px opacity-40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H8M17 7v9" />
          </svg>
        )}
      </a>
    ))}
    <a
      href="https://github.com/huohuastudio/novaix-releases/releases"
      target="_blank"
      class="mt-3 block rounded-lg bg-zinc-900 py-2 text-center text-sm font-medium text-white dark:bg-white dark:text-zinc-900"
    >
      下载
    </a>
  </div>
</header>

<script>
  const hdr = document.getElementById("hdr")!;
  const mbtn = document.getElementById("mbtn")!;
  const mmenu = document.getElementById("mmenu")!;

  let prev = false;
  const onScroll = () => {
    const now = scrollY > 16;
    if (now === prev) return;
    prev = now;
    const isDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
    hdr.style.backgroundColor = now ? (isDark ? "rgba(9,9,11,.82)" : "rgba(255,255,255,.82)") : "";
    hdr.style.backdropFilter = now ? "blur(16px)" : "";
    hdr.style.webkitBackdropFilter = now ? "blur(16px)" : "";
    hdr.style.boxShadow = now ? (isDark ? "0 1px 2px rgba(0,0,0,.2)" : "0 1px 2px rgba(0,0,0,.04)") : "";
  };
  addEventListener("scroll", onScroll, { passive: true });
  window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () => { prev = false; onScroll(); });
  onScroll();

  mbtn.onclick = () => mmenu.classList.toggle("hidden");
  mmenu.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => mmenu.classList.add("hidden")));
</script>
