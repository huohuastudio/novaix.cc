---
interface Plugin {
  id: string;
  name: string;
  version: string;
  description: string;
  type: string;
  author: { name: string; url: string };
}

interface Theme {
  id: string;
  name: string;
  version: string;
  description: string;
  author: { name: string; url: string };
  screenshot?: string;
}

const BASE = "https://raw.githubusercontent.com/huohuastudio/novaix-releases/main";

let plugins: Plugin[] = [];
let themes: Theme[] = [];

try {
  const [pluginRes, themeRes] = await Promise.all([
    fetch(`${BASE}/plugins/index.json`),
    fetch(`${BASE}/themes/index.json`),
  ]);
  if (pluginRes.ok) plugins = (await pluginRes.json()).plugins ?? [];
  if (themeRes.ok) themes = (await themeRes.json()).themes ?? [];
} catch {
  // 构建时获取失败则使用空数组
}

const typeLabels: Record<string, string> = {
  payment: "支付",
  oauth: "登录",
  sms: "短信",
  notify: "通知",
  captcha: "验证",
};

const typeColors: Record<string, string> = {
  payment: "bg-emerald-50 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400",
  oauth: "bg-blue-50 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400",
  sms: "bg-amber-50 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400",
  notify: "bg-purple-50 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400",
  captcha: "bg-rose-50 text-rose-700 dark:bg-rose-900/30 dark:text-rose-400",
};
---

{(plugins.length > 0 || themes.length > 0) && (
  <section class="px-6 py-20 sm:py-28">
    <div class="mx-auto max-w-6xl">
      <div data-animate>
        <p class="font-mono text-xs font-medium uppercase tracking-[0.2em] text-accent">Marketplace</p>
        <h2 class="mt-3 font-display text-2xl font-bold tracking-tight text-zinc-900 sm:text-3xl dark:text-zinc-50">
          插件与主题
        </h2>
        <p class="mt-3 text-zinc-500 dark:text-zinc-400">
          通过插件扩展系统能力，一键安装，即装即用。
          <a
            href="https://github.com/huohuastudio/novaix-releases"
            target="_blank"
            rel="noopener noreferrer"
            class="ml-1 text-accent hover:underline"
          >
            提交你的插件 &rarr;
          </a>
        </p>
      </div>

      {/* 插件 */}
      {plugins.length > 0 && (
        <div class="mt-12">
          <h3 class="mb-6 text-sm font-semibold text-zinc-900 dark:text-zinc-50" data-animate>插件</h3>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {plugins.map((plugin, i) => (
              <div
                class="group rounded-xl border border-zinc-200/60 bg-white p-5 transition-colors hover:border-zinc-300 dark:border-zinc-700/60 dark:bg-zinc-900 dark:hover:border-zinc-600"
                data-animate
                style={`--stagger:${i * 0.06}s`}
              >
                <div class="flex items-center justify-between">
                  <h4 class="font-display text-[0.95rem] font-bold text-zinc-900 dark:text-zinc-50">
                    {plugin.name}
                  </h4>
                  <span class:list={[
                    "rounded-full px-2 py-0.5 text-[0.7rem] font-medium",
                    typeColors[plugin.type] ?? "bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400",
                  ]}>
                    {typeLabels[plugin.type] ?? plugin.type}
                  </span>
                </div>
                <p class="mt-2 text-[0.84rem] leading-relaxed text-zinc-500 dark:text-zinc-400">
                  {plugin.description}
                </p>
                <div class="mt-4 flex items-center justify-between text-xs text-zinc-400 dark:text-zinc-500">
                  <span>{plugin.author.name}</span>
                  <span>v{plugin.version}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* 主题 */}
      {themes.length > 0 && (
        <div class:list={[plugins.length > 0 ? "mt-14" : "mt-12"]}>
          <h3 class="mb-6 text-sm font-semibold text-zinc-900 dark:text-zinc-50" data-animate>主题</h3>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {themes.map((theme, i) => (
              <div
                class="group rounded-xl border border-zinc-200/60 bg-white p-5 transition-colors hover:border-zinc-300 dark:border-zinc-700/60 dark:bg-zinc-900 dark:hover:border-zinc-600"
                data-animate
                style={`--stagger:${i * 0.06}s`}
              >
                <div class="flex items-center justify-between">
                  <h4 class="font-display text-[0.95rem] font-bold text-zinc-900 dark:text-zinc-50">
                    {theme.name}
                  </h4>
                </div>
                <p class="mt-2 text-[0.84rem] leading-relaxed text-zinc-500 dark:text-zinc-400">
                  {theme.description}
                </p>
                <div class="mt-4 flex items-center justify-between text-xs text-zinc-400 dark:text-zinc-500">
                  <span>{theme.author.name}</span>
                  <span>v{theme.version}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
)}
